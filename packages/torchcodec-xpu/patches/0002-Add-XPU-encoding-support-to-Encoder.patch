From: torchcodec-xpu maintainers <noreply@intel.com>
Subject: [PATCH] Add XPU encoding support to Encoder

Widens the three GPU-only encoder branches in
MultiStreamEncoder::initializeVideoStream so that the XPU device type
also takes the hardware encoding path (NV12 default + hw_frames_ctx
setup) provided by XpuDeviceInterface.

Upstream consolidated VideoEncoder::initializeEncoder into
MultiStreamEncoder::initializeVideoStream, so the patch now only needs
to touch that one function.
---
diff --git a/src/torchcodec/_core/Encoder.cpp b/src/torchcodec/_core/Encoder.cpp
--- a/src/torchcodec/_core/Encoder.cpp
+++ b/src/torchcodec/_core/Encoder.cpp
@@ -470,7 +470,7 @@ void MultiStreamEncoder::initializeVideoStream(VideoStream& videoStream) {
   AVPixelFormat outPixelFormat = AV_PIX_FMT_NONE;
 
   if (videoStream.options.pixelFormat.has_value()) {
-    if (deviceType == kStableCUDA) {
+    if (deviceType == kStableCUDA || deviceType == kStableXPU) {
       STD_TORCH_CHECK(
           false,
           "Video encoding on GPU currently only supports the nv12 pixel format. "
@@ -479,7 +479,7 @@ void MultiStreamEncoder::initializeVideoStream(VideoStream& videoStream) {
     outPixelFormat =
         validatePixelFormat(*avCodec, videoStream.options.pixelFormat.value());
   } else {
-    if (deviceType == kStableCUDA) {
+    if (deviceType == kStableCUDA || deviceType == kStableXPU) {
       // Default to nv12 pixel format when encoding on GPU.
       outPixelFormat = DeviceInterface::CUDA_ENCODING_PIXEL_FORMAT;
     } else {
@@ -537,7 +537,7 @@ void MultiStreamEncoder::initializeVideoStream(VideoStream& videoStream) {
         0);
   }
 
-  if (deviceType == kStableCUDA) {
+  if (deviceType == kStableCUDA || deviceType == kStableXPU) {
     videoStream.deviceInterface->registerHardwareDeviceWithCodec(
         videoStream.avCodecContext.get());
     videoStream.deviceInterface->setupHardwareFrameContextForEncoding(
-- 
